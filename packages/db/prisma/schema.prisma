generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma/client"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String           @id @unique @default(uuid())
  email            String           @unique
  name             String?
  userName         String?          @unique
  image            String?
  avatarConfig     String?
  password         String?
  emailVerified    DateTime?
  status           UserStatus       @default(OFFLINE)
  statusMessage    String?
  lastSeen         DateTime         @default(now())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  Account          Account[]
  channelMessages  ChannelMessage[]
  receivedMessages DirectMessage[]  @relation("ReceivedDirectMessages")
  sentMessages     DirectMessage[]  @relation("SentDirectMessages")
  ownedProjects    Projects[]       @relation("ProjectsOwner")
  Session          Session[]
  settings         UserSettings?
  channels         Channel[]        @relation("ChannelMembers")
  friends          User[]           @relation("UserFriends")
  friendOf         User[]           @relation("UserFriends")
  Projects         Projects[]       @relation("UserToProjects")
  ownedGroupChats  GroupChat[]       @relation("GroupChatOwner")
  groupChats       GroupChat[]       @relation("GroupChatMembers")
  groupMessages    GroupMessage[]
}

model Account {
  id                String  @id @unique @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @unique @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id      String   @id @unique @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model ResetPasswordToken {
  id      String   @id @unique @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model UserSettings {
  id            Int     @id @unique @default(autoincrement())
  theme         Theme   @default(LIGHT)
  notifications Boolean @default(true)
  soundEnabled  Boolean @default(true)
  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DirectMessage {
  id         Int      @id @unique @default(autoincrement())
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isRead     Boolean  @default(false)
  senderId   String
  receiverId String
  receiver   User     @relation("ReceivedDirectMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentDirectMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([receiverId, isRead])
  @@index([receiverId, senderId, createdAt])
}

model Channel {
  id          Int              @id @unique @default(autoincrement())
  name        String
  description String?
  type        ChannelType      @default(TEXT)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  workspaceId Int
  workspace   Projects         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages    ChannelMessage[]
  members     User[]           @relation("ChannelMembers")

  @@index([workspaceId])
}

model ChannelMessage {
  id        Int      @id @unique @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isEdited  Boolean  @default(false)
  channelId Int
  senderId  String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id])

  @@index([channelId])
  @@index([senderId])
}

model Projects {
  id          Int          @id @unique @default(autoincrement())
  name        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  ownerId     String
  userId      String?
  Channels    Channel[]
  owner       User         @relation("ProjectsOwner", fields: [ownerId], references: [id])
  whiteboards Whiteboard[]
  users       User[]       @relation("UserToProjects")

  @@index([ownerId])
}

model Whiteboard {
  id          Int      @id @unique @default(autoincrement())
  title       String
  content     Bytes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  workspaceId Int
  workspace   Projects @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model GroupChat {
  id        Int            @id @unique @default(autoincrement())
  name      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  ownerId   String
  owner     User           @relation("GroupChatOwner", fields: [ownerId], references: [id])
  members   User[]         @relation("GroupChatMembers")
  messages  GroupMessage[]

  @@index([ownerId])
}

model GroupMessage {
  id        Int      @id @unique @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isEdited  Boolean  @default(false)
  groupId   Int
  senderId  String
  group     GroupChat @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id])

  @@index([groupId])
  @@index([senderId])
  @@index([groupId, createdAt])
}

enum UserStatus {
  ONLINE
  IDLE
  DO_NOT_DISTURB
  OFFLINE
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum ChannelType {
  TEXT
  VOICE
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}
