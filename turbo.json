{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "NEXTAUTH_SECRET",

    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",

    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",

    "MAIL_USER",
    "MAIL_PASSWORD",

    "NEXT_PUBLIC_BASE_URL",
    "NEXTAUTH_URL",
    "AUTH_TRUST_HOST",

    "NEXT_PUBLIC_SERVER_BASE_URL",

    "ACCESS_TOKEN_SECRET",
    "REFRESH_TOKEN_SECRET",

    "SERVER_PORT",

    "NEXT_PUBLIC_SENTRY_DSN",
    "SENTRY_DSN",
    "SENTRY_AUTH_TOKEN",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": ["NODE_ENV"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    }
  }
}
